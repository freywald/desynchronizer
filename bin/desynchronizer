#!/bin/bash

[[ -z "${__DESYNCHRONIZER_INCLUDE_ONCE_LIBRARY:-}" ]] && source -- "$(realpath "$(dirname -- "${BASH_SOURCE[0]}")/../")/library/main"

# parse arguments

long_options="route-configuration-file:,interactive,transport::"
original_program_arguments=("$@")
parsed_options2=$(getopt --options=":" --longoptions="$long_options" --name "$0" -- "$@") ||:

eval "set -- $parsed_options2"
parsed_options=("$@")
set -- "${original_program_arguments[@]}"

route_configuration_file_argument=""
interactive=false
target_backup_directory_path="backup-files"
source_backup_directory_path_exclude=""
transport="rsync"
find_route=true

input_parameters=()
len=${#parsed_options[@]}
i=0
while (( i<len )); do
	case "${parsed_options[i]}" in
		--transport)
			transport="${parsed_options[i+1]}"
			((i++))||:
			;;
		--route-configuration-file)
			route_configuration_file_argument="${parsed_options[i+1]}"
			indirect_call_by_route_file=true
			((i++))||:
			;;
		--interactive)
			routes_file="$__script_path/configuration/INTERACTIVE.desynchronize"
			find_route=false
			interactive=true
			;;
		--)
			;;
		*)
			input_parameters+=("${parsed_options[i]}")
			;;
	esac

	((i++))||:
done

set -- "${input_parameters[@]}"

# evaluate arguments

if $find_route; then
	if [[ -z "$route_configuration_file_argument" ]]; then
		routes_files=( "./"*".desynchronize" )

		if (( ${#routes_files[@]} == 0 )); then
			routes_files=( "./🖧/"*".desynchronize" )
		fi

		if (( ${#routes_files[@]} == 0 )); then
			routes_files=( "./🖧.desynchronizer/"*".desynchronize" )
		fi

		possible_route_configuration_file_argument=${1:-}
		if [[ -n "$possible_route_configuration_file_argument" ]]; then
			routes_file="$possible_route_configuration_file_argument.desynchronize"

			#remove current program argument $1 from $original_program_arguments
			new_array=()
			index_removed=0
			for parameter in "${original_program_arguments[@]}"; do
				if [[ "${parameter:0:1}" != "-" && "${parameter:1:1}" != "-" && $index_removed == 0 ]]; then
					index_removed=1

					continue
				fi
				new_array+=("$parameter")
			done

			original_program_arguments=("${new_array[@]}")
			original_program_arguments+=("--non-cli")
			shift ||:
		elif (( ${#routes_files[@]} == 0 )); then
			echo>&2 -e "ERROR: No route definition file found! (search expression: *.desynchronize)"

			exit 1
		elif (( ${#routes_files[@]} > 1 )); then
			PS3="Which route file shall be used?"

			select name in "${routes_files[@]}"; do
				for reply in $REPLY; do
					if [[ "$reply" =~ ^[1-9]+[0-9]*$ ]]; then
						if (( ${#routes_files[@]} <= reply-1 )); then
							continue
						fi

						routes_file="${routes_files[reply-1]}"
						if [[ -n "$routes_file" ]]; then
							 break 2
						fi
					fi
				done
			done
		else
			routes_file="${routes_files[0]}"
		fi

		original_program_arguments+=("--non-cli")
	else
		routes_files=()
		if $indirect_call_by_route_file; then
			if [[ $route_configuration_file_argument == "$0" ]]; then
				route_configuration_file_argument=""
			else
				routes_file="$route_configuration_file_argument"
			fi
		fi
	fi
fi

if [[ ! -f "$routes_file" ]]; then
	echo>&2 -e "ERROR: route definition file \"$routes_file\" NOT found!"

	exit 1
fi

route_name="${routes_file%.*}"

if [[ -n "${1:-}" ]]; then

	#remove current program argument $1 from $original_program_arguments
	new_array=()
	index_removed=0
	for parameter in "${original_program_arguments[@]}"; do
		if [[ "${parameter:0:1}" != "-" && "${parameter:1:1}" != "-" && $index_removed == 0 ]]; then
			index_removed=1

			continue
		fi
		new_array+=("$parameter")
	done
	original_program_arguments=("${new_array[@]}")
	original_program_arguments+=("--select-path=$1")
	shift ||:
fi

if ! $indirect_call_by_route_file; then
	# shellcheck source=/dev/null
	set -- "$@" "${original_program_arguments[@]}"

	# shellcheck disable=SC1090
	source -- "$routes_file"

	exit
fi

source -- "$__script_path/library/$transport"
route_base_name="$(basename -- "$route_name")"

# main

desynchronize_with_configuration "${original_program_arguments[@]}"

#route defaults

ignore_arguments=("--route-configuration-file" "--transport")
forwardable_parameter="rsync-options"

length=1
current_line_number=1
i=0
cursor=0
for (( r = 0; r < queue_configuration_options_count; r++)); do
	wideness="${queue_configuration_options_wideness[r]}"

	template="%ROUTE_TYPE% '%ROUTE_NAME%'\n\n%DESCRIPTION%"
	description=""
	apply_seal=false
	filter_rules_file=""
	source_pre_hook=""
	source_post_hook=""
	target_pre_hook=""
	target_post_hook=""
	select_path=""
	default_filter_rules_file=""
	debug=false
	target_backup_directory_path_changed=false
	source_backup_directory_path_exclude_changed=false
	direction=""
	is_cli=true
	is_mirror=false
	is_copy=false
	is_sync=false
	is_archive=false
	remote_host_name=""
	target_directory_name=""
	source=""
	target=""
	is_compact_format=false
	verbose=false
	simulate=false
	verify=false
	ignore_directories=false
	forwarded_parameters=()
	queue_parameters=()
	structure_postfix=""

	for queue_configuration_option in "${queue_configuration_options[@]:$cursor:$wideness}"; do
		queue_parameters+=("$queue_configuration_option")
	done

	long_options="select-path::,output-template::,output-description::,non-cli,simulate,verify,ignore-directories,debug,verbose,compact-format,create-archive::,create-mirror::,create-copy::,sync-remote::,direction::,source::,target::,source-pre-hook::,source-post-hook::,target-pre-hook::,target-post-hook::,target-backup-directory-path::,source-backup-directory-path-exclude::"
	parsed_options2=$(getopt --options="::" --longoptions="$long_options" --name "$0" -- "${queue_parameters[@]}") ||:

	# shellcheck disable=SC2128
	eval "set -- $parsed_options2"
	parsed_options=("$@")
	set -- "${original_program_arguments[@]}"

	len=${#parsed_options[@]}
	i=0
	while (( i<len )); do
		case "${parsed_options[i]}" in
			--create-archive)
				is_archive=true
				# apply_seal=true
				#structure_postfix=".desynchronized.archive"
				target_directory_name="${parsed_options[i+1]}"
				if [[ -z "$target_directory_name" ]]; then
					echo>&2 -e "ERROR: --create-archive requires value target_directory_name."

					exit 1
				fi
				((i++))||:
				;;
			--create-mirror)
				is_mirror=true
				#structure_postfix=".desynchronized.mirror"
				target_directory_name="${parsed_options[i+1]}"
				if [[ -z "$target_directory_name" ]]; then
					echo>&2 -e "ERROR: --create-mirror requires value target_directory_name."

					exit 1
				fi
				((i++))||:
				;;
			--create-copy)
				is_copy=true
				#structure_postfix=".desynchronized.copy"
				target_directory_name="${parsed_options[i+1]}" # allowed to be empty
				((i++))||:
				;;
			--sync-remote)
				is_sync=true
				remote_host_name="${parsed_options[i+1]}"
				if [[ -z "$remote_host_name" ]]; then
					echo>&2 -e "ERROR: --sync-remote requires value remote_host_name."

					exit 1
				fi
				((i++))||:
				;;
			--compact-format)
				is_compact_format=true
				;;
			--target)
				target="${parsed_options[i+1]}"
				if [[ -z "$target" ]]; then
					echo>&2 -e "ERROR: --target must have a value."

					exit 1
				fi
				((i++))||:
				;;
			--source)
				source="${parsed_options[i+1]}"
				if [[ -z "$source" ]]; then
					echo>&2 -e "ERROR: --source must have a value."

					exit 1
				fi
				((i++))||:
				;;
			--output-description)
				description="${parsed_options[i+1]}"
				if [[ -z "$description" ]]; then
					echo>&2 -e "ERROR: --output-description must have a value."

					exit 1
				fi
				((i++))||:
				;;
			--output-template)
				template="${parsed_options[i+1]}"
				if [[ -z "$template" ]]; then
					echo>&2 -e "ERROR: output-template must have a value."

					exit 1
				fi
				((i++))||:
				;;
			--source-pre-hook)
				source_pre_hook="${parsed_options[i+1]}"
				if [[ -z "$source_pre_hook" ]]; then
					echo>&2 -e "ERROR: --source_pre_hook must have a value."

					exit 1
				fi
				((i++))||:
				;;
			--source-post-hook)
				source_post_hook="${parsed_options[i+1]}"
				if [[ -z "$source_post_hook" ]]; then
					echo>&2 -e "ERROR: --source_post_hook must have a value."

					exit 1
				fi
				((i++))||:
				;;
			--target-pre-hook)
				target_pre_hook="${parsed_options[i+1]}"
				if [[ -z "$target_pre_hook" ]]; then
					echo>&2 -e "ERROR: --target_pre_hook must have a value."

					exit 1
				fi
				((i++))||:
				;;
			--target-post-hook)
				target_post_hook="${parsed_options[i+1]}"
				if [[ -z "$target_post_hook" ]]; then
					echo>&2 -e "ERROR: --target_post_hook must have a value."

					exit 1
				fi
				((i++))||:
				;;
			--select-path)
				select_path="${parsed_options[i+1]}"
				if [[ -z "$select_path" ]]; then
					echo>&2 -e "ERROR: --select_path must have a value."

					exit 1
				fi
				((i++))||:
				;;
			--direction)
				direction="${parsed_options[i+1]}"
				if [[ -z "$direction" ]]; then
					echo>&2 -e "ERROR: --direction must have a value."

					exit 1
				fi
				if [[ "$direction" != "upload" && "$direction" != "download" ]]; then
					echo>&2 -e "ERROR: --direction must either be 'upload' or 'download', you specified '$direction'."

					exit 1
				fi
				((i++))||:
				;;
			--target-backup-directory-path)
				target_backup_directory_path="${parsed_options[i+1]}"
				target_backup_directory_path_changed=true
				if [[ "${target_backup_directory_path:0:1}" == "/" ]]; then
					echo>&2 -e "ERROR: --target-backup-directory-path cannot be an absolute path."

					exit 1
				fi
				((i++))||:
				;;
			--source-backup-directory-path-exclude)
				source_backup_directory_path_exclude="${parsed_options[i+1]}"
				source_backup_directory_path_exclude_changed=true
				if [[ "${source_backup_directory_path_exclude:0:1}" == "/" ]]; then
					echo>&2 -e "ERROR: --source-backup-directory-path-exclude cannot be an absolute path."

					exit 1
				fi
				((i++))||:
				;;
			--non-cli)
				is_cli=false
				;;
			--debug)
				debug=true
				;;
			--verbose)
				verbose=true
				;;
			--ignore-directories)
				ignore_directories=true
				;;
			--simulate)
				simulate=true
				;;
			--verify)
				verify=true
				;;
			--)
				if [[ -n "${parsed_options[i+1]:-}" ]]; then
					echo>&2 "Unexpected parameter: ${parsed_options[i+1]:-}"

					exit 1
				fi

				((i++))||:
				break
				;;
			*)
				echo>&2 "UNKNOWN_PARAM: ${parsed_options[i]}"

				exit 1
				;;
		esac
		((i++))||:
	done

	if [[ -z "$description" ]]; then
		symbol=""
		if [[ "$transport" == "rclone" ]]; then
			symbol="🖧"
		fi
		if [[ "$direction" == "upload" ]]; then
			description="\t\t─  %ROUTE_DESCRIPTION%\n\t\t─  %DIRECTORY_NAME% '%SOURCE%' ⟶ $symbol %TARGET_DEVICE_DESCRIPTION%"
		elif [[ "$direction" == "download" || $direction == "" ]]; then
			description="\t\t─  %ROUTE_DESCRIPTION%\n\t\t─  %DIRECTORY_NAME% $symbol '%SOURCE%' ⟶ %TARGET_DEVICE_DESCRIPTION%"
		fi
	fi

	declare -A output_variables=()
	input_not_parsed=()
	for argument in "${original_program_arguments[@]}"; do
		name="${argument%%=*}"
		value="${argument#*=}"
		not_done=true

		if [[ "$argument" =~ --output-variable-* ]]; then
			name=${name:18}
			name="${name//-/_}"
			output_variables["${name^^}"]="$value"
			not_done=false
		fi

		if $not_done && [[ "--$forwardable_parameter" == "$name" ]]; then
			if [[ "${name:0:2}" == "--" ]]; then
				forwarded_parameters+=( "$argument" )
				not_done=false
			fi
		fi

		if $not_done && ! __array_contains "$name" "${parsed_options[@]}" && ! __array_contains "$name" "${ignore_arguments[@]}"; then
			if [[ "${argument:0:1}" == "-" && "${argument:1:1}" != "-" ]]; then
				forwarded_parameters+=( "$argument" )
			else
				#input_not_parsed+=( "$argument" )
				forwarded_parameters+=( "$argument" )
			fi
			not_done=false
		fi
	done

	if (( ${#input_not_parsed[@]} > 0 )); then
			echo>&2 -e "ERROR: unknown parameters:\n"
			for queue_configuration_option in "${input_not_parsed[@]}"; do
				echo>&2 -e "\t* $queue_configuration_option"
			done
		exit 1
	fi

	interactive_data_user_confirmed=false

	while ! $interactive_data_user_confirmed; do
		#@todo fixme, also, missing section for rclone, this is for rsync
		while [[ -z "$source" ]]; do
			interactive=true
			read -rp "Enter source: " "source" ||:
			[[ -n "$source" ]] && break
		done

		while [[ -z "$target" ]]; do
			interactive=true
			read -rp "Enter target: " "target" ||:
			[[ -n "$source" ]] && break
		done

		if $interactive; then
			echo "Source: $source"
			echo "Target: $target"

			read -rp "Is this correct? (Y/N): " "confirm" ||:
			[[ "$confirm" == [yY] || "$confirm" == [yY][eE][sS] ]] && break
			source=""
			target=""
		else
			break
		fi
	done

	if $is_cli; then
		show_banner=true
		show_more=false
		verbose=true
	else
		show_banner=false
		show_more=true
	fi

	current_date_as_string="$(date +"%d.%m.%Y [%H∶%M∶%S]")" #@fixme use from library/base
	current_date="$(date +%Y%m%d%H%M%S)" #@fixme use from library/base

	if [[ "$filter_rules_file" == "" && -f "$__current_directory/$route_name.filter-rules" ]]; then
		filter_rules_file="$route_name.filter-rules"
	fi

	rule_file_real_path="$(dirname -- "$(realpath --quiet --canonicalize -- "$PWD/$route_name.desynchronize")")"
	if [[ "$filter_rules_file" == "" && -f "$rule_file_real_path/$route_name.filter-rules" ]]; then
		filter_rules_file="$rule_file_real_path/$route_name.filter-rules"
	fi

	if [[ "$filter_rules_file" == "" && -f "$route_name.filter-rules" ]]; then
		filter_rules_file="$route_name.filter-rules"
	fi

	if [[ -z "$select_path" && -f "$__script_path/configuration/default.filter-rules.$transport" ]]; then
		default_filter_rules_file="$__script_path/configuration/default.filter-rules.$transport"
	elif [[ -n "$select_path" && -f "$__script_path/configuration/default-select-path.filter-rules.$transport" ]]; then
		default_filter_rules_file="$__script_path/configuration/default-select-path.filter-rules.$transport"
	fi

	# @todo hooks will not work with rclone !?
	if [[ -n "$source_pre_hook" ]]; then
		if [[ "${source_pre_hook:0:1}" != "/" ]]; then
			source_pre_hook="$source/$source_pre_hook"
		fi
		source_pre_hook="$(realpath --quiet -- "$source_pre_hook")"
	fi

	if [[ -n "$source_post_hook" ]]; then
		if [[ "${source_post_hook:0:1}" != "/" ]]; then
			source_post_hook="$source/$source_post_hook"
		fi
		source_post_hook="$(realpath --quiet -- "$source_post_hook")"
	fi

	if [[ -n "$target_pre_hook" ]]; then
		if [[ "${target_pre_hook:0:1}" != "/" ]]; then
			target_pre_hook="$target/$target_pre_hook"
		fi
		target_pre_hook="$(realpath --quiet -- "$target_pre_hook")"
	fi

	if [[ -n "$target_post_hook" ]]; then
		if [[ "${target_post_hook:0:1}" != "/" ]]; then
			target_post_hook="$target/$target_post_hook"
		fi
		target_post_hook="$(realpath --quiet -- "$target_post_hook")"
	fi

	if [[ -n "$source_pre_hook" ]]; then
		if [[ "${source_pre_hook:0:1}" != "/" ]]; then
			source_pre_hook="$source/$source_pre_hook"
		fi
		source_pre_hook="$(realpath --quiet -- "$source_pre_hook")"
	fi

	if [[ -n "$source_post_hook" ]]; then
		if [[ "${source_post_hook:0:1}" != "/" ]]; then
			source_post_hook="$source/$source_post_hook"
		fi
		source_post_hook="$(realpath --quiet -- "$source_post_hook")"
	fi

	if [[ -n "$target_pre_hook" ]]; then
		if [[ "${target_pre_hook:0:1}" != "/" ]]; then
			target_pre_hook="$target/$target_pre_hook"
		fi
		target_pre_hook="$(realpath --quiet -- "$target_pre_hook")"
	fi

	if [[ -n "$target_post_hook" ]]; then
		if [[ "${target_post_hook:0:1}" != "/" ]]; then
			target_post_hook="$target/$target_post_hook"
		fi
		target_post_hook="$(realpath --quiet -- "$target_post_hook")"
	fi

	if [[ -z "$target_pre_hook" ]]; then
		target_pre_hook="$source_pre_hook"
	fi

	if [[ -z "$target_post_hook" ]]; then
		target_post_hook="$source_post_hook"
	fi

	root_source="$source"
	root_target="$target"
	root_target_directory_name="$target_directory_name"

	if $is_copy; then
		if [[ -n "$target_directory_name" ]]; then
			target_directory_name="$target_directory_name/"
		fi
		target_directory_name="${target_directory_name}files"
	fi

	if [[ -n "$target_directory_name" ]]; then
		target="$target/$target_directory_name"
	fi

	if [[ -n "$select_path" ]]; then
		source="$source/$select_path"
		target="$target/$select_path"
	fi

	if $debug; then
		echo -ne "\n\n forwarded_parameters:\n"
		for queue_configuration_option2 in "${forwarded_parameters[@]}"; do
			echo -e "\t* $queue_configuration_option2"
		done

		[[ -n "$source_pre_hook" ]] && echo "source_pre_hook: $source_pre_hook"
		[[ -n "$source_post_hook" ]] && echo "source_post_hook: $source_post_hook"
		[[ -n "$target_pre_hook" ]] && echo "target_pre_hook: $target_pre_hook"
		[[ -n "$target_post_hook" ]] && echo "target_post_hook: $target_post_hook"
		echo
	fi

	custom_options=("${forwarded_parameters[@]}")

	if [[ "$transport" == "rsync" ]]; then
		if [[ -n "$default_filter_rules_file" ]]; then
			custom_options+=(--filter="merge $default_filter_rules_file")
		fi

		if [[ -n "$filter_rules_file" ]]; then
			custom_options+=(--filter="merge $filter_rules_file")
		fi
	elif [[ "$transport" == "rclone" ]]; then
    	if [[ -n "$default_filter_rules_file" ]]; then
    		custom_options+=(--filter-from="$default_filter_rules_file")
    	fi

    	if [[ -n "$filter_rules_file" ]]; then
    		custom_options+=(--filter-from="$filter_rules_file")
    	fi
    else
    	:
    fi

	route_type=""
	options_that_take_precedence_last=()

	source_base_name=$(basename -- "$source")
	target_base_name=$(basename -- "$target")

	if [[ $transport == "rsync" ]]; then #@todo move to rsync-handler
		if $is_archive; then
			route_type="ARCHIVE"
			target="$target$structure_postfix"

			if $is_compact_format; then
				route_type="COMPACT ARCHIVE"

				if [[ -n "$target_directory_name" ]]; then
					synchronizer_application_data_path="$root_target/$target_directory_name/.desynchronizer/$current_date_as_string"
				else
					synchronizer_application_data_path="$root_target/.desynchronizer/$current_date_as_string"
				fi

				options_that_take_precedence_last+=(--exclude='/.desynchronizer/')
				options_that_take_precedence_last+=(--filter='hide /.desynchronizer/') # when --delete-excluded is used, then do not delete this item, even if it is excluded
				options_that_take_precedence_last+=(--filter='protect /.desynchronizer/') # when --delete-excluded is used, then do not delete this item, even if it is excluded
			else
				synchronizer_application_data_path="$root_target/$target_directory_name.desynchronizer/$current_date_as_string"
			fi

		elif $is_mirror; then
			route_type="MIRROR"
			target="$target$structure_postfix"

			if $is_compact_format; then
				route_type="COMPACT MIRROR"

				if [[ -n "$target_directory_name" ]]; then
					synchronizer_application_data_path="$root_target/$target_directory_name/.desynchronizer/$current_date_as_string"
				else
					synchronizer_application_data_path="$root_target/.desynchronizer/$current_date_as_string"
				fi

				options_that_take_precedence_last+=(--exclude='/.desynchronizer/')
				options_that_take_precedence_last+=(--filter='hide /.desynchronizer/') # when --delete-excluded is used, then do not delete this item, even if it is excluded
				options_that_take_precedence_last+=(--filter='protect /.desynchronizer/') # when --delete-excluded is used, then do not delete this item, even if it is excluded
			else
				synchronizer_application_data_path="$root_target/$target_directory_name.desynchronizer/$current_date_as_string"
			fi

		elif $is_copy; then
			route_type="COPY"

			if $is_compact_format; then
				route_type="COMPACT COPY"

				if [[ -n "$root_target_directory_name" ]]; then
					synchronizer_application_data_path="$root_target/$target_directory_name/.desynchronizer/$current_date_as_string"
				else
					synchronizer_application_data_path="$root_target/.desynchronizer/$current_date_as_string"
				fi

				options_that_take_precedence_last+=(--exclude='/.desynchronizer/')
				options_that_take_precedence_last+=(--filter='hide /.desynchronizer/') # when --delete-excluded is used, then do not delete this item, even if it is excluded
				options_that_take_precedence_last+=(--filter='protect /.desynchronizer/') # when --delete-excluded is used, then do not delete this item, even if it is excluded
			else
				if [[ -n "$root_target_directory_name" ]]; then
					synchronizer_application_data_path="$root_target/$root_target_directory_name/desynchronizer/$current_date_as_string"
				else
					synchronizer_application_data_path="$root_target/desynchronizer/$current_date_as_string"
				fi
			fi

		fi

		backup_directory="$synchronizer_application_data_path/$target_backup_directory_path"
		mkdir --parents -- "$synchronizer_application_data_path/" || exit 1
		if ! $simulate; then
			mkdir --parents -- "$backup_directory/" || exit 1
		fi
	elif [[ "$transport" == "rclone" ]]; then #@todo move to rsync-handler
		if ! $is_sync; then
        	echo "--sync is missing for --rclone"
        	exit 1
        fi
		if [[ -z "$remote_host_name" ]]; then
			echo "remote_host_name is empty for --rclone"
			exit 1
		fi
		if [[ -z "$direction" ]]; then
        	echo "--direction is missing for --rclone"
        	exit 1
        fi
		route_type="SYNC"
		if [[ "$direction" == "download" ]]; then
			#host_prepend="$remote_host_name:"
			#if [[ "${source:0:1}" != "/" ]]; then
			#	host_prepend="$remote_host_name:/"
			#fi
       	 	#source="$host_prepend$source"
       	 	source="$remote_host_name:/$(__right_normalize_absolute_path "$source")"

			target_directory_name="$(basename -- "$root_target")"
			synchronizer_application_data_path="$(realpath --quiet --no-symlinks --canonicalize-missing "$root_target/../$target_directory_name.desynchronizer/$current_date_as_string")"
			if ! $target_backup_directory_path_changed; then
				target_backup_directory_path="$local_archive_directory_name"
       	 	fi
			if ! $source_backup_directory_path_exclude_changed; then
				source_backup_directory_path_exclude="$cloud_archive_directory_name"
       	 	fi

			target_backup_directory_path="$(__normalize_absolute_path "$target_backup_directory_path")"
			source_backup_directory_path_exclude="$(__normalize_absolute_path "$source_backup_directory_path_exclude")"

       	 	options_that_take_precedence_last+=(--exclude="$target_backup_directory_path")
			options_that_take_precedence_last+=(--exclude="$source_backup_directory_path_exclude")

			backup_directory_base="$root_target/$target_backup_directory_path/"
        	if [[ -d "$backup_directory_base" && ! -f "$backup_directory_base/DESYNCHRONIZER-BACKUP-FLAGFILE" ]]; then
        		echo "Error: backup_directory '"$backup_directory_base"' is missing the flag file DESYNCHRONIZER-BACKUP-FLAGFILE to mark it as the backup directory. Existing directories cannot be used as an backup directory for safety reasons."
        		exit 1
        	fi
        elif [[ "$direction" == "upload" ]]; then
			#host_prepend="$remote_host_name:"
			#if [[ "${target:0:1}" != "/" ]]; then
			#	host_prepend="$remote_host_name://"
			#fi
       	 	#target="$host_prepend$target"

       	 	target="$remote_host_name:/$(__right_normalize_absolute_path "$target")"

			source_directory_name="$(basename -- "$root_source")"
			synchronizer_application_data_path="$(realpath --quiet --no-symlinks --canonicalize-missing "$root_source/../$source_directory_name.desynchronizer/$current_date_as_string")"

			#host_prepend="$remote_host_name:"
			#if [[ "${root_target:0:1}" != "/" ]]; then
			#	host_prepend="$remote_host_name://"
			#fi
       	 	#root_target1="$host_prepend$root_target"

       	 	root_target1="$remote_host_name:/$(__right_normalize_absolute_path "$root_target")"

       	 	if ! $target_backup_directory_path_changed; then
       	 		target_backup_directory_path="$cloud_archive_directory_name"
       	 	fi
			if ! $source_backup_directory_path_exclude_changed; then
				source_backup_directory_path_exclude="$local_archive_directory_name"
       	 	fi

			target_backup_directory_path="$(__normalize_absolute_path "$target_backup_directory_path")"
			source_backup_directory_path_exclude="$(__normalize_absolute_path "$source_backup_directory_path_exclude")"

       	 	options_that_take_precedence_last+=(--exclude="$target_backup_directory_path")
			options_that_take_precedence_last+=(--exclude="$source_backup_directory_path_exclude")

        	backup_directory_base="$root_target1/$target_backup_directory_path/"

        	#rclone lsf "$backup_directory_base/DESYNCHRONIZER-BACKUP-FLAGFILE"
        	#@todo verify online that "$backup_directory_base/DESYNCHRONIZER-BACKUP-FLAGFILE" exists
        	#if [[ -d "$backup_directory_base" && ! -f "$backup_directory_base/DESYNCHRONIZER-BACKUP-FLAGFILE" ]]; then
        	#	echo "Error: backup_directory '$backup_directory_base' is missing the flag file DESYNCHRONIZER-BACKUP-FLAGFILE to mark it as the backup directory. Existing directories cannot be used as an backup #directory for safety reasons."
        	#	exit 1
        	#fi
        fi

        backup_directory="$backup_directory_base/$(date +"%d.%m.%Y [%H∶%M∶%S]")/"
		mkdir --parents -- "$synchronizer_application_data_path/" || exit 1

		if ! $simulate; then
			if [[ "$direction" == "download" ]]; then
				mkdir --parents -- "$backup_directory/" || exit 1

				if [[ ! -f "$backup_directory_base/DESYNCHRONIZER-BACKUP-FLAGFILE" ]]; then
					touch -- "$backup_directory_base/DESYNCHRONIZER-BACKUP-FLAGFILE" || exit 1
				fi
			elif [[ "$direction" == "upload" ]]; then
				#@todo verify that file "$backup_directory_base/DESYNCHRONIZER-BACKUP-FLAGFILE" exists online! if not touch it!
				:
			fi
		fi

	else
		echo "Error: unknown transport method '$transport'!"
		exit 1
	fi

	full_log_file="$synchronizer_application_data_path/default.log"
	error_log_file="$synchronizer_application_data_path/error.log"

	description_string="$template"
	output_variables["DESCRIPTION"]="$description"
	output_variables["SOURCE_NAME"]="$source_base_name"
	output_variables["TARGET_NAME"]="$target_base_name"
	output_variables["ROUTE_NAME"]="$route_base_name"
	output_variables["ROUTE_TYPE"]="$route_type"
	output_variables["SOURCE"]="$source"

	inner_parse_depth=3
	for i in $(seq 1 $inner_parse_depth); do
		for output_variable in "${!output_variables[@]}"; do
			value="${output_variables["$output_variable"]}"
			description_string="${description_string//%$output_variable%/"$value"}"
		done
	done

	if $show_banner; then
		echo -e "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
		echo -e "DESYNCHRONIZER ⸺  synchronize by desynchronizing, disorganize by reorganizing."
		echo -e "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
	fi

	echo -e "$description_string"
	if $show_more; then
		echo -en "\n\n"
		echo -e "Source:\t\t\t\t\t\t\t\t\t$source"
		echo -e "Target:\t\t\t\t\t\t\t\t\t$target"
		echo -e "Desynchronizer application data path:\t$synchronizer_application_data_path"
	fi
	echo -en "\n\n"

	if $simulate; then
		$debug && echo "SIMULATE ON"
		custom_options+=("--dry-run")
	fi
	if $verify; then
		$debug && echo "VALIDATE ON"
		custom_options+=("--checksum")
	fi
	if $ignore_directories; then
		$debug && echo "IGNORE DIRECTORIES ON"
		custom_options+=(--exclude='__IGNORED🖧/')
		custom_options+=(--filter='hide __IGNORED🖧/')
		custom_options+=(--filter='protect __IGNORED🖧/')
	fi

	if $verbose; then
		read -r -p "Press enter to continue…" ||:
		__nclr 1

		echo -en "\nROUTE CONFIGURATION\n\n"
		for option in "${queue_parameters[@]}"; do
			if $debug || (! $debug && [[ ! "$option" =~ --output-* ]]); then
				echo -e "\t\t─  '$option'"
			fi
		done

		echo -en "\n\n"
		read -r -p "Press enter to continue…" ||:
		__nclr 0

		echo -e "COMPLETE RSYNC SHELL COMMAND LINE STRING:\n"
		#echo -e "\trsync" "${custom_options[@]}" -habHAXE --delete --delete-excluded --info=progress2 --inplace --backup --force --progress --stats --log-file="$full_log_file" --backup-dir="$backup_directory" "${options_that_take_precedence_last[@]}" -- "$source/" "$target/" "2> $error_log_file"
		transport_as_string

		echo -ne "\n\n\n"

		read -r -p "Please review this configuration, and then press the enter or data release key to start the final desynchronization process…" ||:
		__nclr 0
	else
		if $is_cli; then
			read -r -p "Please review this configuration, and then press the enter or data release key to start the final desynchronization process…" ||:
			__nclr 0
		else
			read -r -p "Please review this configuration, and then press the enter or data release key to start the final desynchronization process…" ||:
			__nclr 0
        fi
	fi

	if ! $simulate && $apply_seal; then
		echo -ne "removing seal from '$target' …"
		sudo chattr -R -i -- "$target/" 2>"/dev/null"
		echo -ne "done!\n"
	fi


	[[ -n "$source_pre_hook" ]] && (cd -- "$source" && "$source_pre_hook" "pre" "source" "$simulate" )
	[[ -n "$target_pre_hook" ]] && (cd -- "$target" && "$target_pre_hook" "pre" "target" "$simulate" )

	#echo -e "rsync" "${custom_options[@]}" -habHAXE --delete --delete-excluded --info=progress2 --inplace --backup --force --progress --stats --log-file="$full_log_file" --backup-dir="$backup_directory" "${options_that_take_precedence_last[@]}" -- "$source/" "$target/" "2> $error_log_file" > "$synchronizer_application_data_path/CMD"

	transport_as_string > "$synchronizer_application_data_path/CMD"

	# --max-alloc=5g
	#rsync "${custom_options[@]}" -habHAXE --delete --delete-excluded --info=progress2 --inplace --backup --force --progress --stats --log-file="$full_log_file" --backup-dir="$backup_directory" "${options_that_take_precedence_last[@]}" -- "$source/" "$target/" 2> "$error_log_file"||:

	set -x
	start_transport ||:
	set +x

	cat -- "$error_log_file"

	if ! $simulate; then
		if $is_archive; then
			echo >| "$target/🤍🩵💙 \$desynchronized\$ 💙🩵🤍"

			if $is_compact_format && [[ -z "$target_directory_name" ]]; then
				echo >| "$target/💜🩷❤️ DO NOT TOUCH THE HIDDEN DIRECTORY .desynchronizer 💜🩷❤️"
			fi

			echo >| "$target/🧡💛💚 DO NOT TOUCH ANY OF THESE FILES HERE, IT'S AN ARCHIVE. 💕 LET US ☼LIVE☼ HERE ☺ 💕 💚💛🧡"
		elif $is_mirror; then
			echo >| "$target/🤍🩵💙 \$desynchronized\$ 💙🩵🤍"

			if $is_compact_format && [[ -z "$target_directory_name" ]]; then
				echo >| "$target/💜🩷❤️ DO NOT TOUCH THE HIDDEN DIRECTORY .desynchronizer 💜🩷❤️"
			fi

			echo >| "$target/🧡💛💚 DO NOT TOUCH ANY OF THESE FILES HERE, IT'S A MIRROR. 💕 LET US ☼LIVE☼ HERE ☺ 💕 💚💛🧡"
		fi
	fi

	[[ -n "$source_post_hook" ]] && (cd -- "$source" && "$source_post_hook" "post" "source" "$simulate" )
	[[ -n "$target_post_hook" ]] && (cd -- "$target" && "$target_post_hook" "post" "target" "$simulate" )

	if [[ "$transport" == "rsync" ]]; then #@todo move to rsync-handler
		[[ -d "$synchronizer_application_data_path/$target_backup_directory_path" && -z "$(ls -1qA -- "$synchronizer_application_data_path/$target_backup_directory_path" 2>"/dev/null")" ]] && rmdir -- "$synchronizer_application_data_path/$target_backup_directory_path"
	elif [[ "$transport" == "rclone" ]]; then #@todo move to rclone-handler
		[[ -d "$backup_directory" && -z "$(ls -1qA -- "$backup_directory" 2>"/dev/null")" ]] && rmdir -- "$backup_directory"
		[[ -d "$backup_directory_base" && -z "$(ls -1qA -- "$backup_directory_base" 2>"/dev/null")" ]] && rmdir -- "$backup_directory_base"
	else
		:
	fi

	[[ -f "$full_log_file" && ! -s "$full_log_file" ]] && rm -- "$full_log_file"
	[[ -f "$error_log_file" && ! -s "$error_log_file" ]] && rm -- "$error_log_file"

	if ! $simulate && $apply_seal; then
		echo -ne "\n"
		echo -ne "applying seal to '$target' …"
		sudo chattr -R +i -- "$target/" 2>"/dev/null"
		echo -ne "done!\n"
	fi

	echo -ne "\n"

	((cursor+=wideness))
	((current_line_number+=1))
	((i+=length))
done

