function __message() { # @source: https://github.com/MitMaro/server-rsync-backup
	echo -e "[${__COLOR_LOG_DATE}$(date '+%d.%m.%Y %H:%M:%S')${__COLOR_RESET}] $*"
}

function __error() { # @source: https://github.com/MitMaro/server-rsync-backup
	# use error code provided if set, else last commands error code
	# local last_exit_code=${2-$?}
	printf_format_string="$1"
	shift ||:

	>&2 __message "${__COLOR_ERROR}[ERROR]${__COLOR_RESET} $(printf "$printf_format_string" "$@")"
	>&2 echo

	exit 140
}

function __exit_failsafe() {
	exit 140
}

function __warn() { # @source: https://github.com/MitMaro/server-rsync-backup
	printf_format_string="$1"
	shift ||:

	__message "${__COLOR_WARNING}[WARNING]${__COLOR_RESET} $(printf "$printf_format_string" "$@")"
}

function __debug() { # @source: https://github.com/MitMaro/server-rsync-backup
	printf_format_string="$1"
	shift ||:

	__message "${__COLOR_DEBUG}[DEBUG]${__COLOR_RESET} $(printf "$printf_format_string" "$@")"
}

function __verbose() { # @source: https://github.com/MitMaro/server-rsync-backup
	printf_format_string="$1"
	shift ||:

	if $__verbose; then
		__message "${__COLOR_VERBOSE}[VERBOSE]${__COLOR_RESET} $(printf "$printf_format_string" "$@")"
	fi
}

function __info() { # @source: https://github.com/MitMaro/server-rsync-backup
	printf_format_string="$1"
	shift ||:

	__message "${__COLOR_INFO}[INFO]${__COLOR_RESET} $(printf "$printf_format_string" "$@")"
}

function __log() { # @source: https://github.com/MitMaro/server-rsync-backup
	printf_format_string="$1"
	shift ||:

	__message "${__COLOR_LOG}[LOG]${__COLOR_RESET} $(printf "$printf_format_string" "$@")"
}

function __highlight() { # @source: https://github.com/MitMaro/server-rsync-backup
	if [[ -z "$__COLOR_HIGHLIGHT" ]]; then
		echo "\`$*\`"
	else
		echo "${__COLOR_HIGHLIGHT}$*${__COLOR_RESET}"
	fi
}

function __usage_example() { # @source: https://github.com/MitMaro/server-rsync-backup
	if (( $# > 0 )); then
		contents="$1"
		echo "$contents"
		echo -e
	else
		echo -e
		echo -e "rsync backup"
		echo -e
		echo -e "Usage: $0 [options] <path-to-config-root>"
		echo -e
		echo -e "Options:"
		echo -e "  $(__highlight "--id <id>")         Only sync files for provided id."
		echo -e
		echo -e "  $(__highlight "--verbose, -v")     Show more verbose output of actions performed."
		echo -e
		echo -e "  $(__highlight "--no-color")        Disable colored output."
		echo -e
		echo -e "  $(__highlight "--dry-run")         Run rsync in dry run mode. Providing this options also assumes $(__highlight "--verbose")."
		echo -e
		echo -e "  $(__highlight "--help")            Show this usage message and exit."
		echo -e
	fi
}

function __set_title() {
  echo -ne "\e]0;"
  echo -n "$@"
  echo -ne "\a"
}

function __set_tab_stops() {
	tab_width="$1"
	terminal_width="$( stty size | awk '{print $2}' )"

	set_tab_stops() {
		local tab_width=$1 terminal_width=$2 tab_stops=''

		for (( i=1+tab_width; i<terminal_width; i+=tab_width )); do
			tab_stops+=$i','
		done

		tabs $tab_stops
	}

	set_tab_stops "$tab_width" "$terminal_width"
}

function __press_any_key_to_continue() {
  read -n 1 -s -r -p "Press any key to continue…" "__pressed_key" ||:
  echo
}

function __press_some_key_to_continue() {
  read -n 1 -s -r -p "Press the '$1' key to continue…" "__pressed_key" ||:
  echo
}
