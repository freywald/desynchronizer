#!/bin/bash

local_archive_directory_name="local-file-archive/"
cloud_archive_directory_name="cloud-file-archive/"

function transport_as_string() {
	if [[ "$direction" == "upload" ]]; then
		echo -e "\trclone sync ${custom_options[*]} --modify-window 2s --create-empty-src-dirs --no-update-dir-modtime --skip-links --retries=1 --transfers=1 --verbose --progress-terminal-title --stats-one-line --progress --checksum --ignore-size --check-first --update --track-renames --metadata ---log-file=\"$full_log_file\" --backup-dir \"$backup_directory/\" ${options_that_take_precedence_last[*]} -- \"$source/\" \"$target\" 2> \"$error_log_file\""

	elif [[ "$direction" == "download" ]]; then
		echo -e "\trclone sync ${custom_options[*]} --modify-window 2s --create-empty-src-dirs ---no-update-dir-modtime --skip-links --retries=1 --transfers=1 --verbose --progress-terminal-title --stats-one-line --progress --checksum --ignore-size --check-first --update --track-renames --metadata --log-file=\"$full_log_file\" --delete-during --backup-dir \"$backup_directory/\" ${options_that_take_precedence_last[*]} -- \"$source/\" \"$target\" 2> \"$error_log_file\""

	fi
}

function start_transport() {
	if [[ "$direction" == "upload" ]]; then
		# --dump filters disabled because it enables --verbose, see https://github.com/rclone/rclone/issues/5790
		2> >(tee -a "$error_log_file" | tee -a "$full_log_file" >&2) rclone sync "${custom_options[@]}" --modify-window 2s --create-empty-src-dirs --no-update-dir-modtime --skip-links --retries=1 --transfers=1 --verbose --progress-terminal-title --stats-one-line --progress --checksum --ignore-size --check-first --update --track-renames --metadata --backup-dir "$backup_directory/" "${options_that_take_precedence_last[@]}" -- "$source/" "$target" | tee -a "$full_log_file" ||__expression_may_fail

	elif [[ "$direction" == "download" ]]; then
		# --dump filters disabled because it enables --verbose, see https://github.com/rclone/rclone/issues/5790
		2> >(tee -a "$error_log_file" | tee -a "$full_log_file" >&2) rclone sync "${custom_options[@]}" --modify-window 2s --create-empty-src-dirs --no-update-dir-modtime --skip-links --retries=1 --transfers=1 --verbose --progress-terminal-title --stats-one-line --progress --checksum --ignore-size --check-first --update --track-renames --metadata --delete-during --backup-dir "$backup_directory/" "${options_that_take_precedence_last[@]}" -- "$source/" "$target" | tee -a "$full_log_file" ||__expression_may_fail
	fi
}

